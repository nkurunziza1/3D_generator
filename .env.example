# --- Replicate TRELLIS.2 (real GLB mesh, no local GPU) — recommended ---
# No spaces after = signs (RECONSTRUCTION_MODEL=replicate not RECONSTRUCTION_MODEL= replicate)
REPLICATE_API_TOKEN=r8_your_token_here
REPLICATE_MODEL=fishwowater/trellis2
# 512 | 1024 | 1024_cascade (cascade often hits 500 on Replicate)
REPLICATE_PIPELINE_TYPE=1024
REPLICATE_TEXTURE_SIZE=1024
REPLICATE_MAX_IMAGE_SIDE=1024
REPLICATE_GENERATE_VIDEO=false
# Network timeouts (seconds) — increase if SSL handshake times out
REPLICATE_CONNECT_TIMEOUT=120
REPLICATE_READ_TIMEOUT=900
REPLICATE_DOWNLOAD_TIMEOUT=600
RECONSTRUCTION_MODEL=replicate

# --- OpenRouter (point-cloud preview from body analysis) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_REFERER=http://localhost:3000

# mock | replicate | openrouter | vggt | vgg-t3

# Hugging Face (only for local vggt / vgg-t3)
HF_TOKEN=
HF_MODEL_ID=nvidia/vgg-ttt

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
